@model Velore_Studio.Models.Testimonial

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <title>Yeni Rəy — Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f4f6f9; padding: 40px; }
        .form-card { max-width: 600px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        .btn-save { background: #c07a5a; color: #fff; }
    </style>
</head>
<body>

<div class="form-card">
    <h4 class="mb-4">Yeni Rəy Əlavə Et</h4>

    <form method="post" action="/Admin/CreateTestimonial">

        <div class="mb-3">
            <label class="form-label">Müştərinin Adı</label>
            <input type="text" name="Name" class="form-control" required />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Vəzifəsi</label>
            <input type="text" name="Role" class="form-control" placeholder="Baku Residence Sahibi" required/>
        </div>

        <div class="mb-3">
            <label class="form-label">Rəy Mətni</label>
            <textarea name="Message" class="form-control" rows="3" required></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Şəklin Yolu</label>
            <input type="text" name="Image" class="form-control" placeholder="/images/leyla.jpg" required />
        </div>

        <button type="submit" class="btn btn-save w-100">Saxla</button>
        <a href="/Admin/Testimonials" class="btn btn-light w-100 mt-2">Ləğv Et</a>

    </form>
</div>

</body>
</html>