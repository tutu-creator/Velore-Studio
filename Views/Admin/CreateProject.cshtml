@model Velore_Studio.Models.Project

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <title>Yeni Layihə — Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #f4f6f9; padding: 40px; }
        .form-card { max-width: 600px; margin: 0 auto; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        .btn-save { background: #c07a5a; color: #fff; }
    </style>
</head>
<body>

<div class="form-card">
    <h4 class="mb-4">Yeni Layihə Əlavə Et</h4>

    <form method="post" action="/Admin/CreateProject">

        <div class="mb-3">
            <label class="form-label">Layihənin Adı</label>
            <input type="text" name="Title" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Kateqoriya</label>
            <select name="Category" class="form-select" required>
                <option value="İnteryer">İnteryer</option>
                <option value="Brendinq">Brendinq</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Təsvir</label>
            <textarea name="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Şəklin Yolu</label>
            <input type="text" name="ImageUrl" class="form-control" placeholder="/images/proje1.jpg" required />
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" name="IsFeatured" class="form-check-input" value="true" />
            <label class="form-check-label">Ana Səhifədə Göstər</label>
        </div>

        <button type="submit" class="btn btn-save w-100">Saxla</button>
        <a href="/Admin/Projects" class="btn btn-light w-100 mt-2">Ləğv Et</a>

    </form>
</div>

</body>
</html>