@model IEnumerable<Velore_Studio.Models.Project>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Layihələr — Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f4f6f9; }
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #1a1a2e;
            position: fixed;
            top: 0; left: 0;
            padding: 30px 20px;
        }
        .sidebar .brand { color: #fff; font-size: 18px; font-weight: bold; margin-bottom: 10px; }
        .sidebar .dot { color: #c07a5a; }
        .sidebar .divider { border-color: #333; margin: 15px 0; }
        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #aaa;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.2s;
        }
        .sidebar a:hover, .sidebar a.active { background: #c07a5a; color: #fff; }
        .main { margin-left: 250px; padding: 30px; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="brand">Velore Studio<span class="dot"> •</span></div>
    <small class="text-secondary">Admin Panel</small>
    <hr class="divider" />
    <a href="/Admin"><i class="bi bi-grid"></i> Dashboard</a>
    <a href="/Admin/Projects" class="active"><i class="bi bi-image"></i> Layihələr</a>
    <a href="/Admin/Testimonials"><i class="bi bi-chat-quote"></i> Rəylər</a>
    <a href="/Admin/Messages"><i class="bi bi-envelope"></i> Mesajlar</a>
</div>

<div class="main">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Layihələr</h4>
        <a href="/Admin/CreateProject" class="btn btn-sm" style="background:#c07a5a; color:#fff;">
            <i class="bi bi-plus-lg"></i> Yeni Layihə
        </a>
    </div>

    <div class="bg-white rounded-3 shadow-sm">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Şəkil</th>
                    <th>Ad</th>
                    <th>Kateqoriya</th>
                    <th>Ana Səhifə</th>
                    <th>Tarix</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model)
                {
                    <tr>
                        <td><img src="@project.Image" width="60" height="40" style="object-fit:cover; border-radius:4px;" /></td>
                        <td>@project.Title</td>
                        <td>@project.Category</td>
                        <td>@(project.IsFeatured ? "✅" : "❌")</td>
                        <td>@project.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/DeleteProject/@project.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>