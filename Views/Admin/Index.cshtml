@{
    Layout = null;
    ViewData["Title"] = "Admin Panel";
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Panel — Velore Studio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background: #f4f6f9; }
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #1a1a2e;
            position: fixed;
            top: 0; left: 0;
            padding: 30px 20px;
        }
        .sidebar .brand {
            color: #fff;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .sidebar .dot { color: #c07a5a; }
        .sidebar .divider { border-color: #333; margin: 15px 0; }
        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #aaa;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: all 0.2s;
        }
        .sidebar a:hover, .sidebar a.active {
            background: #c07a5a;
            color: #fff;
        }
        .main { margin-left: 250px; padding: 30px; }
        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
        .stat-card .icon {
            width: 50px; height: 50px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
        }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="brand">Velore Studio<span class="dot"> •</span></div>
    <small class="text-secondary">Admin Panel</small>
    <hr class="divider" />
    <a href="/Admin" class="active"><i class="bi bi-grid"></i> Dashboard</a>
    <a href="/Admin/Projects"><i class="bi bi-image"></i> Layihələr</a>
    <a href="/Admin/Testimonials"><i class="bi bi-chat-quote"></i> Rəylər</a>
    <a href="/Admin/Messages"><i class="bi bi-envelope"></i> Mesajlar</a>
    <a href="/Admin/Logout"><i class="bi bi-box-arrow-right"></i> Çıxış</a>
</div>

<div class="main">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0">Dashboard</h4>
            <small class="text-muted">Xoş gəldiniz, Admin!</small>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Layihələr</p>
                        <h3 class="mb-0">@ViewBag.ProjectCount</h3>
                    </div>
                    <div class="icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-image"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Rəylər</p>
                        <h3 class="mb-0">@ViewBag.TestimonialCount</h3>
                    </div>
                    <div class="icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-chat-quote"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Yeni Mesajlar</p>
                        <h3 class="mb-0">@ViewBag.UnreadMessageCount</h3>
                    </div>
                    <div class="icon bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>