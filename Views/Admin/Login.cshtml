@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Giriş — Velore Studio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f4f6f9;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .login-card {
            background: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 400px;
        }
        .brand { color: #1a1a2e; font-weight: bold; font-size: 20px; }
        .dot { color: #c07a5a; }
        .btn-login { background: #c07a5a; color: #fff; width: 100%; }
        .btn-login:hover { background: #a8623e; color: #fff; }
    </style>
</head>
<body>

<div class="login-card">
    <div class="text-center mb-4">
        <div class="brand">Velore Studio<span class="dot"> •</span></div>
        <small class="text-muted">Admin Panel</small>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form action="/Admin/Login" method="post">
        <div class="mb-3">
            <label class="form-label">İstifadəçi adı</label>
            <input type="text" name="username" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Şifrə</label>
            <input type="password" name="password" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-login">Daxil ol</button>
    </form>
</div>

</body>
</html>