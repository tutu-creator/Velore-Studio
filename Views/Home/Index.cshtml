@{
    ViewData["Title"] = "Ana Səhifə";
}

<!-- HERO SECTION -->
<section class="hero">
    <div class="container hero-grid">
        <div class="hero-content">
            <span class="section-tag">Xoş gəlmisiniz</span>
            <h1>Dizaynın <span class="serif-italic">zərif</span> və ruh oxşayan harmoniyası</h1>
            <p class="hero-subtitle">
                Hər bir məkanı özünəməxsus hekayəsi olan yaşayış sahəsinə çeviririk. Velore Studio sizə minimalist, isti və funksional dizayn həlləri təklif edir.
            </p>
            <div class="hero-buttons">
                <a href="/Home/Portfolio" class="btn btn-primary">
                    Layihələrə Bax
                    <svg class="btn-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="/Home/Contact" class="btn btn-outline">Əlaqə Qurun</a>
            </div>
        </div>
        <div class="hero-image-wrapper">
            <img src="~/assets/hero.jpg" alt="Müasir minimalist qonaq otağı dizaynı">
        </div>
    </div>
</section>

<!-- PHILOSOPHY / ABOUT TEASER -->
<section class="section">
    <div class="container philosophy-grid">
        <div class="philosophy-images">
            <div class="phil-img-1">
                <img src="~/assets/phil-1.jpg" alt="Yataq otağının estetika detalları">
            </div>
        </div>
        <div class="philosophy-content">
            <span class="section-tag">Bizim Fəlsəfəmiz</span>
            <h2>İşıq, məkan və təbii materialların vəhdəti</h2>
            <p>
                Biz inanırıq ki, yaxşı dizayn yalnız gözəl görünmək deyil, həm də insana dinclik verməkdir. İşlərimizdə təbii işıqdan, yumşaq rəng tonlarından və təbii materiallardan (ağac, daş, kətan) istifadə edərək ruh oxşayan atmosfer yaradırıq.
            </p>
            <p>
                Hər bir müştərinin ehtiyaclarını və həyat tərzini dərindən analiz edərək, təkcə estetikanı deyil, həm də gündəlik istifadə rahatlığını (funksionallığı) ön plana çıxarırıq.
            </p>
            <a href="/Home/About" class="btn btn-outline" style="margin-top: 1rem;">Bizim hekayəmiz</a>
        </div>
    </div>
</section>

<!-- SERVICES SECTION -->
<section class="section bg-light">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Xidmətlərimiz</span>
            <h2>Məkanınıza dəyər qatan peşəkar dizayn xidmətləri</h2>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon-wrapper">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </div>
                <h3>Interyer Dizaynı</h3>
                <p>Fərdi evlər, mənzillər və villalar üçün tam konseptual dizayn layihələrinin hazırlanması, 3D vizuallaşdırma və rəng-material seçimləri.</p>
            </div>
            <div class="service-card">
                <div class="service-icon-wrapper">
                    <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </div>
                <h3>Brendinq və Kimlik</h3>
                <p>Kommersiya məkanları, kafe və ofislər üçün vizual brend identifikasiyasının yaradılması, məkanın brendin ruhuna uyğun dizayn edilməsi.</p>
            </div>
            <div class="service-card">
                <div class="service-icon-wrapper">
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </div>
                <h3>Müəllif Nəzarəti</h3>
                <p>Dizayn layihəsinin tikinti və təmir mərhələsində tam dəqiqliklə həyata keçirilməsi üçün usta və material tədarükçüləri ilə işə nəzarət edilməsi.</p>
            </div>
        </div>
    </div>
</section>

<!-- SELECTED PORTFOLIO PREVIEW -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Portfolio</span>
            <h2>Seçilmiş Layihələr</h2>
        </div>
        <div class="portfolio-grid" style="margin-bottom: 4rem;">
            @foreach (var project in ViewBag.Projects)
            {
                <a href="/Home/Portfolio" class="portfolio-item">
                    <div class="portfolio-img-box">
                        <img src="@project.Image" alt="@project.Title">
                    </div>
                    <div class="portfolio-info">
                        <div class="portfolio-cat">@project.Category</div>
                        <h3>@project.Title</h3>
                    </div>
                </a>
            }
        </div>
        <div style="text-align: center;">
            <a href="/Home/Portfolio" class="btn btn-outline">Bütün Portfolioya Bax</a>
        </div>
    </div>
</section>

<!-- TESTIMONIALS SECTION -->
<section class="section testimonials-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Rəylər</span>
            <h2>Müştərilərimiz nə deyir?</h2>
        </div>
        <div class="slider-container">
            <div class="testimonials-slider">
                @foreach (var testimonial in ViewBag.Testimonials)
                {
                    <div class="testimonial-slide">
                        <div class="testimonial-quote">
                            "@testimonial.Message"
                        </div>
                        <div class="testimonial-author">
                            <div class="author-img">
                                <img src="@testimonial.Image" alt="@testimonial.Name">
                            </div>
                            <div class="author-info">
                                <h4>@testimonial.Name</h4>
                                <p>@testimonial.Role</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="slider-controls">
                <button class="slider-btn prev" aria-label="Əvvəlki rəy" id="slider-btn-prev">
                    <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </button>
                <button class="slider-btn next" aria-label="Növbəti rəy" id="slider-btn-next">
                    <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section" style="background-color: var(--color-surface); text-align: center;">
    <div class="container" style="max-width: 700px;">
        <span class="section-tag">Birlikdə Yaradaq</span>
        <h2>Məkanınızı yeniləməyə hazırsınız?</h2>
        <p style="margin-bottom: 2.5rem;">
            Gəlin xəyallarınızdakı dizaynı və isti atmosferi birlikdə gerçəkləşdirək. Ehtiyaclarınızı müzakirə etmək üçün bizimlə əlaqə saxlayın.
        </p>
        <a href="/Home/Contact" class="btn btn-primary">Pulsuz Konsultasiya Alın</a>
    </div>
</section>