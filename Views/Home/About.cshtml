@{
    ViewData["Title"] = "Haqqımızda";
}

<!-- ABOUT HERO -->
<section class="about-hero">
    <div class="container">
        <span class="section-tag">Biz Kimik?</span>
        <h1>Hekayəmiz və Fəlsəfəmiz</h1>
        <p>İnsan ruhuna dinclik verən, minimalist və hər detalında zəriflik gizlənən məkanlar yaradırıq.</p>
    </div>
</section>

<!-- INTRO STORY SECTION -->
<section class="section">
    <div class="container about-intro-grid">
        <div class="about-intro-content">
            <span class="section-tag">Yolumuz</span>
            <h2>2015-ci ildən bəri estetik məkanlar dizayn edirik</h2>
            <p>
                Velore Studio fəaliyyətə başladığı ilk gündən etibarən standart dizayn qəliblərindən uzaqlaşmağı hədəfləmişdir. Bizim üçün hər bir layihə boş bir kətan kimidir; müştərilərimizin xəyalları, gündəlik vərdişləri və hissləri ilə rənglənən bir sənət əsərinə çevrilir.
            </p>
            <p>
                İllər ərzində Bakıda və ölkə xaricində onlarla yaşayış və kommersiya məkanının interyer dizaynını, həmçinin unikal brend kimliyini uğurla hazırlamışıq. İşimizə yanaşmamızda sadəlik, dürüstlük və yüksək keyfiyyət ən öndə duran prinsiplərimizdir.
            </p>
        </div>
        <div class="about-intro-img">
            <img src="~/assets/about-intro.jpg" alt="Velore Studio ofis və dizayn masası">
        </div>
    </div>
</section>

<!-- VALUES SECTION -->
<section class="section values-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Dəyərlərimiz</span>
            <h2>Bizi fərqləndirən əsas prinsiplər</h2>
        </div>
        <div class="values-grid">
            <div class="value-item">
                <h3>01 / Minimalizm</h3>
                <p>Gərəksiz detallardan qaçaraq, yalnız ən təmiz və funksional elementləri saxlayırıq. Məkanı vizual olaraq yormayan sadəliyə üstünlük veririk.</p>
            </div>
            <div class="value-item">
                <h3>02 / Keyfiyyət</h3>
                <p>Həm dizayn mərhələsində, həm də təmir-tikintidə istifadə olunan materialların keyfiyyəti və detalların mükəmməlliyi bizim vizit kartımızdır.</p>
            </div>
            <div class="value-item">
                <h3>03 / İnsan Yönümlülük</h3>
                <p>Saytlar və jurnallardakı soyuq dizaynlardan fərqli olaraq, evlərin içində insanın özünü rahat, isti və tam təhlükəsiz hiss edəcəyi atmosfer yaradırıq.</p>
            </div>
        </div>
    </div>
</section>

<!-- TEAM SECTION -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Komandamız</span>
            <h2>Yaradıcı Ruhlarımız</h2>
        </div>
        <div class="team-grid">
            <div class="team-card">
                <div class="team-img-box">
                    <img src="~/assets/team-1.jpg" alt="Leyla Qasımova">
                </div>
                <h3>Leyla Qasımova</h3>
                <p>Təsisçi & Baş Dizayner</p>
            </div>
            <div class="team-card">
                <div class="team-img-box">
                    <img src="~/assets/team-2.jpg" alt="Emin Babayev">
                </div>
                <h3>Emin Babayev</h3>
                <p>Aparıcı Memar</p>
            </div>
            <div class="team-card">
                <div class="team-img-box">
                    <img src="~/assets/team-3.jpg" alt="Sara Əliyeva">
                </div>
                <h3>Sara Əliyeva</h3>
                <p>Brend Strateqi</p>
            </div>
        </div>
    </div>
</section>